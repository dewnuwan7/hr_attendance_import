<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_import_wizard_form" model="ir.ui.view">
        <field name="name">attendance.import.wizard.form</field>
        <field name="model">attendance.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Attendance Logs">

                <field name="state" invisible="1"/>

                <!-- ── DRAFT: upload ─────────────────────────────────── -->
                <group invisible="state != 'draft'">
                    <group>
                        <field name="excel_file"
                               string="Attendance Excel Report"
                               widget="binary"
                               filename="file_name"
                               required="1"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                </group>

                <!-- ── PREVIEW: summary before confirming ────────────── -->
                <group string="Import Summary" invisible="state != 'preview'">
                    <group>
                        <field name="preview_ready"   string="✔ Records to Import"/>
                        <field name="preview_skipped" string="⏭ Rows to Skip"/>
                        <field name="preview_errors"  string="⚠ Warnings / Errors"/>
                    </group>
                </group>
                <group string="Details" invisible="state != 'preview' or not preview_details">
                    <field name="preview_details"
                           nolabel="1"
                           widget="text"
                           readonly="1"
                           style="font-family: monospace; white-space: pre-wrap; width: 100%; min-width: 500px; word-break: break-word;"/>
                </group>

                <!-- ── DONE: results ─────────────────────────────────── -->
                <group string="Import Results" invisible="state != 'done'">
                    <group>
                        <field name="result_created" string="✔ Records Created"/>
                        <field name="result_skipped" string="⏭ Rows Skipped"/>
                        <field name="result_errors"  string="✘ Errors"/>
                    </group>
                </group>
                <group string="Details" invisible="state != 'done'">
                    <field name="result_details"
                           nolabel="1"
                           widget="text"
                           readonly="1"
                           style="font-family: monospace; white-space: pre-wrap; width: 100%; word-break: break-word;"/>
                </group>

                <footer>
                    <button string="Preview"
                            name="action_preview"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"
                            invisible="state != 'draft'"/>

                    <button string="Confirm Import"
                            name="action_confirm_import"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'preview'"/>
                    <button string="Back"
                            name="action_back"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'preview'"/>

                    <button string="Close"
                            name="action_close"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'done'"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Attendance Logs</field>
        <field name="res_model">attendance.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
